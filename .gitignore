# --- Directorio de copias de seguridad ---
backup

# === ESP-IDF / ESP32 (esp32_node) ==========================
# Artefactos de compilacion: se regeneran con `idf.py build`
build/
# Componentes descargados por el gestor de componentes
managed_components/
dependencies.lock
# Copia de seguridad de la configuracion (se conserva sdkconfig)
sdkconfig.old
# Binarios generados
*.elf
*.bin
*.map
*.o

# === Python (gateway_node / sensor_node) ===================
__pycache__/
*.pyc
*.pyo
.venv/
venv/

