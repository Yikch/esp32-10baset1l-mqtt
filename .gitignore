*.lof
*.lot
*.lol
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.idx
*.ilg
*.ind
*.nav
*.snm
*.vrb
*.xdv

# === Datos generados / bases de datos locales ==============
*.db
*.sqlite

# === Sistema operativo y editores ==========================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.tmp
*~
