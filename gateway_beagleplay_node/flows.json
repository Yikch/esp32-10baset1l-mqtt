        "page": "",
        "ui": "",
        "name": "Badge estado sensor",
        "order": 3,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<style>\n    .badge { display:inline-block; padding:8px 18px; border-radius:18px;\n             font-weight:bold; font-family:sans-serif; color:white;\n             min-width:110px; text-align:center; }\n    .ok    { background:#4caf50; }   /* ONLINE + datos frescos */\n    .warn  { background:#ff9800; }   /* ONLINE + sensor fault */\n    .stale { background:#9e9e9e; }   /* ONLINE afirmado pero sin datos (retenido obsoleto) */\n    .ko    { background:#f44336; }   /* OFFLINE */\n    .unk   { background:#9e9e9e; }\n    .reason-text { margin-left:10px; color:#666; font-size:13px; }\n</style>\n\n<div>\n    <span class=\"badge\" :class=\"{\n        'ok':    msg && msg.payload && msg.payload.status === 'ONLINE' && msg.payload.sensor !== 'fault',\n        'warn':  msg && msg.payload && msg.payload.status === 'ONLINE' && msg.payload.sensor === 'fault',\n        'stale': msg && msg.payload && msg.payload.status === 'STALE',\n        'ko':    msg && msg.payload && msg.payload.status === 'OFFLINE',\n        'unk':   !msg || !msg.payload || ['ONLINE','OFFLINE','STALE'].indexOf(msg.payload.status) === -1\n    }\">\n        {{\n            (msg && msg.payload && msg.payload.status === 'ONLINE' && msg.payload.sensor === 'fault')\n                ? 'ONLINE / SENSOR FAULT'\n                : (msg && msg.payload && msg.payload.status === 'STALE')\n                    ? 'SIN DATOS'\n                    : ((msg && msg.payload && msg.payload.status) || 'UNKNOWN')\n        }}\n    </span>\n    <span class=\"reason-text\" v-if=\"msg && msg.payload && msg.payload.reason\">\n        ({{ msg.payload.reason }})\n    </span>\n</div>",
        "storeOutMessages": true,
