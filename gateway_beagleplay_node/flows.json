    {
        "id": "a1756779db247571",
        "type": "function",
        "z": "96b92fe2e5bc89fa",
        "name": "Calcula edad del ultimo dato",
        "func": "const last = flow.get(\"last_data_ts\");\nif (!last) {\n    msg.payload = \"—\";\n    return msg;\n}\n\n// Diferencia en segundos, descontando reloj saltado al futuro.\nlet diffSec = Math.max(0, Math.floor((Date.now() - last) / 1000));\n\nconst days  = Math.floor(diffSec / 86400); diffSec -= days  * 86400;\nconst hours = Math.floor(diffSec / 3600);  diffSec -= hours * 3600;\nconst mins  = Math.floor(diffSec / 60);\nconst secs  = diffSec - mins * 60;\n\nlet text;\nif      (days  > 0) text = `${days} d ${hours} h`;\nelse if (hours > 0) text = `${hours} h ${mins} min`;\nelse if (mins  > 0) text = `${mins} min ${secs} s`;\nelse                text = `${secs} s`;\n\nmsg.payload = text;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
