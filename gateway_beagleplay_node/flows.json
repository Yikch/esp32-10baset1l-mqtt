    {
        "id": "a09e9434ade35eed",
        "type": "function",
        "z": "96b92fe2e5bc89fa",
        "name": "Watchdog datos",
        "func": "// Reset del temporizador cada vez que llega una medicion.\n// Si pasan TIMEOUT_MS sin mensajes, emite un evento OFFLINE sintetico\n// hacia la salida 2.\n\nconst NODE_ID = \"esp32_01\";   // ajustar si gestionas varios sensores\nconst TIMEOUT_MS = 6000;               // 3x el periodo de muestreo (2 s)\n\nconst timer = context.get(\"timer\");\nif (timer) clearTimeout(timer);\n\ncontext.set(\"timer\", setTimeout(() => {\n    node.send([null, {\n        payload: {\n            node: NODE_ID,\n            reason: \"no_data_timeout\",\n            ts: Date.now()\n        }\n    }]);\n    node.status({ fill: \"red\", shape: \"ring\", text: \"timeout\" });\n}, TIMEOUT_MS));\n\nnode.status({ fill: \"green\", shape: \"dot\", text: \"ok\" });\n\nreturn [msg, null];   // salida 1: pasa al pipeline existente",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "// El código añadido aquí se ejecutará una vez\n// cuando el nodo es iniciado.\n// Arranque: arma el temporizador para detectar un nodo ausente desde el inicio.\ncontext.set(\"timer\", setTimeout(() => {\n    node.send([null, { payload: { node: \"esp32_01\", reason: \"no_data_timeout\", ts: Date.now() } }]);\n    node.status({ fill: \"red\", shape: \"ring\", text: \"sin datos (arranque)\" });\n}, 6000));\n",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 260,
        "wires": [
            [
                "8f53300609bd44b8",
                "557416c7a45add17",
                "2462552e2bb179b8"
