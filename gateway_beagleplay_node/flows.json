    {
        "id": "479949dc487c15fe",
        "type": "function",
        "z": "96b92fe2e5bc89fa",
        "name": "Estado efectivo",
        "func": "// Combina el ultimo estado conocido con la frescura de los datos, para no\n// mostrar ONLINE en base a un retenido obsoleto tras reiniciar el gateway.\nconst DATA_TIMEOUT_MS = 6000;   // 3x periodo de muestreo (2 s)\n\n// Si llega un status real (no el tick), lo guardamos como ultimo conocido.\nconst p = msg.payload;\nif (p && (p.status === \"ONLINE\" || p.status === \"OFFLINE\")) {\n    flow.set(\"last_status\", p);\n}\n\nconst st       = flow.get(\"last_status\");\nconst lastData = flow.get(\"last_data_ts\");\nconst fresh    = lastData && (Date.now() - lastData) < DATA_TIMEOUT_MS;\n\nlet eff;\nif (!st) {\n    eff = { status: \"UNKNOWN\" };\n} else if (st.status === \"OFFLINE\") {\n    eff = { status: \"OFFLINE\", reason: st.reason };\n} else {\n    // st.status === \"ONLINE\": exigir confirmacion por datos frescos\n    eff = fresh\n        ? { status: \"ONLINE\", sensor: st.sensor, reason: st.reason }\n        : { status: \"STALE\", reason: \"sin_datos\" };\n}\n\nmsg.payload = eff;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 640,
        "wires": [
            [
                "63d91679f7c22264"
            ]
        ]
    },
    {
        "id": "22d7ef26e5cfb045",
        "type": "function",
        "z": "96b92fe2e5bc89fa",
        "name": "Umbral O2",
        "func": "// Alarma de DEFICIENCIA de oxigeno: alarma por umbral INFERIOR.\n// Entrada: msg.payload = valor de O2 (numero), proveniente de \"Filtro O₂\".\nconst NODE_ID  = \"esp32_01\";\nconst O2_MIN   = 19.5;     // %vol: por debajo => alarma\nconst O2_CLEAR = 20.0;     // %vol: histeresis, debe recuperar por encima para limpiar\nconst val = Number(msg.payload);\nif (Number.isNaN(val)) return null;\nconst wasActive = context.get(\"o2_alarm\") || false;\nlet alarm = null;\nif (!wasActive && val < O2_MIN) {\n    context.set(\"o2_alarm\", true);\n    alarm = { severity: \"critical\", kind: \"gas_threshold\", node: NODE_ID,\n              reason: \"o2_low\", value: val, min: O2_MIN, unit: \"%vol\", ts: Date.now() };\n    node.status({ fill: \"red\", shape: \"dot\", text: `O2 ${val}% < ${O2_MIN}` });\n} else if (wasActive && val >= O2_CLEAR) {\n    context.set(\"o2_alarm\", false);\n    alarm = { severity: \"info\", kind: \"gas_threshold\", node: NODE_ID,\n              reason: \"o2_clear\", value: val, min: O2_MIN, unit: \"%vol\", ts: Date.now() };\n    node.status({ fill: \"green\", shape: \"ring\", text: `O2 ${val}% OK` });\n}\nif (!alarm) return null;\nmsg.topic   = \"v1/spe/alarm\";\nmsg.payload = alarm;\nmsg.qos     = 1;\nmsg.retain  = false;   // no machacar el retenido de la alarma de presencia\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
