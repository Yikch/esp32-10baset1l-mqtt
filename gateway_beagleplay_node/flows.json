    {
        "id": "6653c2700e72f4fe",
        "type": "function",
        "z": "96b92fe2e5bc89fa",
        "name": "system_status → InfluxDB",
        "func": "// Entrada esperada:\n//   { node, status: \"ONLINE\"|\"OFFLINE\", reason?, sensor?: \"ok\"|\"fault\" }\n//\n// Cambios respecto a la version anterior:\n//   - Se lee payload.sensor (campo nuevo del firmware ESP32).\n//   - Se persiste como tag adicional 'sensor_health' en system_status.\n//   - Salida 2 propaga al consolidador de alarmas tambien cuando\n//     el nodo esta ONLINE pero sensor=fault (alarma de sensor averiado).\n\nconst ev = msg.payload || {};\nconst isOnline    = ev.status === \"ONLINE\";\nconst sensorOk    = ev.sensor !== \"fault\";   // ok si esta ausente o \"ok\"\nconst isAlarmable = !isOnline || !sensorOk;  // OFFLINE o sensor averiado\n\n// --- Salida 1: persistencia en InfluxDB (siempre) ---\nconst dbMsg = {\n    measurement: \"system_status\",\n    payload: [\n        { state_code: isOnline ? 1 : 0 },                  // FIELDS\n        {                                                  // TAGS\n            nodo:          ev.node || \"unknown\",\n            reason:        ev.reason || (isOnline ? \"ok\" : \"unknown\"),\n            sensor_health: ev.sensor || (isOnline ? \"ok\" : \"n/a\"),\n            source:        \"lwt\"\n        }\n    ]\n};\n\n// --- Salida 2: hacia consolidador si OFFLINE o si sensor=fault ---\nconst alarmMsg = !isAlarmable ? null : {\n    payload: {\n        node:   ev.node || \"unknown\",\n        reason: !isOnline ? (ev.reason || \"link_dropped\")\n                          : \"sensor_fault\",\n        kind:   !isOnline ? \"sensor_lost\" : \"sensor_degraded\",\n        ts:     Date.now()\n    }\n};\n\nreturn [dbMsg, alarmMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 400,
        "wires": [
            [
                "f3ba892e0a25ec82"
            ],
            [
                "d90e212a6e102287"
            ]
        ]
    },
