        "func": "// Reenvia todas las medidas como telemetria numerica (clave en minusculas).\nconst datos = msg.payload || {};\nconst out = {};\nfor (const k of Object.keys(datos)) {\n    const n = Number(datos[k]);\n    out[k.toLowerCase()] = Number.isNaN(n) ? datos[k] : n;\n}\nmsg.payload = out;        // p. ej. { o2: 20.9, o3: 5 } o { co_level: 400 }\nreturn msg;",
