    {
        "id": "fb7146cec2042ca7",
        "type": "ui-template",
        "z": "96b92fe2e5bc89fa",
        "group": "4f19cf733bbdf287",
        "page": "",
        "ui": "",
        "name": "Botón reinicio",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<div>\n  <button class=\"btn-reboot\" @click=\"open = true\">⏻ Reiniciar nodo</button>\n\n  <div v-if=\"open\" class=\"modal-overlay\" @click.self=\"open = false\">\n    <div class=\"modal-box\">\n      <p class=\"modal-title\">¿Reiniciar el nodo ESP32?</p>\n      <p class=\"modal-text\">\n        El nodo publicará <b>OFFLINE / shutdown</b> y se reiniciará.\n        La serie de datos tendrá una laguna durante el arranque.\n      </p>\n      <div class=\"modal-actions\">\n        <button class=\"btn-cancel\"  @click=\"open = false\">Cancelar</button>\n        <button class=\"btn-confirm\" @click=\"doReboot\">Sí, reiniciar</button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\nexport default {\n  data() {\n    return { open: false };\n  },\n  methods: {\n    doReboot() {\n      this.send({ payload: \"reboot\" });   // sale por la salida del ui-template\n      this.open = false;\n    }\n  }\n}\n</script>\n\n<style>\n  .btn-reboot {\n    background:#f44336; color:#fff; border:none;\n    padding:10px 18px; border-radius:8px; font-weight:600;\n    cursor:pointer; font-family:sans-serif;\n  }\n  .btn-reboot:hover { background:#d32f2f; }\n\n  .modal-overlay {\n    position:fixed; inset:0; background:rgba(0,0,0,.45);\n    display:flex; align-items:center; justify-content:center; z-index:9999;\n  }\n  .modal-box {\n    background:#fff; border-radius:10px; padding:22px 24px;\n    max-width:360px; box-shadow:0 8px 30px rgba(0,0,0,.25);\n    font-family:sans-serif;\n  }\n  .modal-title { font-size:17px; font-weight:700; margin:0 0 8px; color:#222; }\n  .modal-text  { font-size:13px; color:#555; margin:0 0 18px; line-height:1.4; }\n  .modal-actions { display:flex; justify-content:flex-end; gap:10px; }\n  .btn-cancel {\n    background:#eee; color:#333; border:none; padding:8px 16px;\n    border-radius:6px; cursor:pointer; font-weight:600;\n  }\n  .btn-confirm {\n    background:#f44336; color:#fff; border:none; padding:8px 16px;\n    border-radius:6px; cursor:pointer; font-weight:600;\n  }\n  .btn-confirm:hover { background:#d32f2f; }\n</style>",
