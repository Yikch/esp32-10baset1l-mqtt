        "format": "<style>\n    .ev-table {\n        width: 100%;\n        border-collapse: collapse;\n        font-family: sans-serif;\n        font-size: 13px;\n    }\n    .ev-table th, .ev-table td {\n        padding: 8px 10px;\n        text-align: left;\n        border-bottom: 1px solid #eee;\n        vertical-align: middle;\n    }\n    .ev-table th {\n        background: #f5f5f5;\n        font-weight: 600;\n        color: #555;\n        font-size: 12px;\n        text-transform: uppercase;\n        letter-spacing: 0.5px;\n    }\n    .ev-table tbody tr:hover { background: #fafafa; }\n    .ev-pill {\n        display: inline-block;\n        padding: 4px 12px;\n        border-radius: 12px;\n        color: white;\n        font-weight: 600;\n        font-size: 12px;\n        min-width: 140px;\n        text-align: center;\n        white-space: nowrap;\n    }\n    .ev-empty {\n        padding: 20px;\n        text-align: center;\n        color: #999;\n        font-style: italic;\n    }\n</style>\n\n<div v-if=\"!msg || !msg.payload || msg.payload.length === 0\" class=\"ev-empty\">\n    Sin eventos registrados todavía\n</div>\n\n<table class=\"ev-table\" v-if=\"msg && msg.payload && msg.payload.length > 0\">\n    <thead>\n        <tr>\n            <th>Tiempo</th>\n            <th>Nodo</th>\n            <th>Evento</th>\n        </tr>\n    </thead>\n    <tbody>\n        <tr v-for=\"(r, idx) in msg.payload\" :key=\"idx\">\n            <td>{{ r.ts }}</td>\n            <td>{{ r.node }}</td>\n            <td>\n                <span class=\"ev-pill\" :style=\"{ background: r.color }\">\n                    {{ r.icon }} {{ r.label }}\n                </span>\n            </td>\n        </tr>\n    </tbody>\n</table>",
