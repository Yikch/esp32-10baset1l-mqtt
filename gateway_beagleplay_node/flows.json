    {
        "id": "215cf90e0416231e",
        "type": "ui-template",
        "z": "96b92fe2e5bc89fa",
        "group": "fd45f722b4b1b15d",
        "page": "",
        "ui": "",
        "name": "Banner O2",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<div v-if=\"active\" class=\"o2-banner\">\n    <span class=\"o2-icon\">⚠️</span>\n    <span class=\"o2-text\">\n    <b>ALARMA · O₂ BAJO</b> — {{ value }} %vol\n    (umbral {{ threshold }} %vol). Atmósfera deficiente en oxígeno.\n  </span>\n</div>\n<script>\n    export default {\n  data() {\n    return { active: false, value: null, threshold: 19.5 };\n  },\n  watch: {\n    msg: {\n      immediate: true,\n      handler(m) {\n        if (!m || !m.payload) return;\n        const r = m.payload.reason;\n        if (r === 'o2_low') {\n          this.active = true;\n          this.value = m.payload.value;\n          if (m.payload.min != null) this.threshold = m.payload.min;\n        } else if (r === 'o2_clear') {\n          this.active = false;\n          this.value = m.payload.value;\n        }\n      }\n    }\n  }\n}\n</script>\n<style>\n    .o2-banner {\n        display: flex;\n        align-items: center;\n        gap: 10px;\n        background: #f44336;\n        color: #fff;\n        padding: 12px 16px;\n        border-radius: 8px;\n        font-family: sans-serif;\n        font-weight: 600;\n        box-shadow: 0 2px 8px rgba(0, 0, 0, .2);\n        animation: o2pulse 1.2s ease-in-out infinite;\n    }\n\n    @keyframes o2pulse {\n\n        0%,\n        100% {\n            opacity: 1;\n        }\n\n        50% {\n            opacity: .6;\n        }\n    }\n\n    .o2-icon {\n        font-size: 22px;\n    }\n\n    .o2-text {\n        font-size: 14px;\n        line-height: 1.3;\n    }\n</style>",
