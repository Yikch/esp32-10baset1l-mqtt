    {
        "id": "d90e212a6e102287",
        "type": "function",
        "z": "96b92fe2e5bc89fa",
        "name": "Consolidador de alarma",
        "func": "// Construye el payload unificado de alarma.\n// Entrada esperada en msg.payload:\n//   { node, reason, ts }\n\nconst ev = msg.payload || {};\n\nconst alarm = {\n    severity: ev.kind === \"sensor_degraded\" ? \"warning\" : \"critical\",\n    kind:     ev.kind || \"sensor_lost\",\n    node:     ev.node || \"unknown\",\n    reason:   ev.reason || \"link_dropped\",\n    ts:       ev.ts || Date.now()\n};\n\n// --- Salida 1: publicacion MQTT retenida en v1/spe/alarm ---\nconst mqttMsg = {\n    topic: \"v1/spe/alarm\",\n    payload: alarm,\n    qos: 1,\n    retain: true\n};\n\n// --- Salida 2: persistencia en InfluxDB (mismo measurement que estado) ---\nconst dbMsg = {\n    measurement: \"system_status\",\n    payload: [\n        { state_code: 0 },                        // FIELDS\n        {                                         // TAGS\n            nodo: alarm.node,\n            reason: alarm.reason,\n            source: \"alarm\"\n        }\n    ]\n};\n\nreturn [mqttMsg, dbMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
