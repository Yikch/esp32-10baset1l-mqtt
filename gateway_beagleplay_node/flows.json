    {
        "id": "d7883c71c730b00e",
        "type": "function",
        "z": "96b92fe2e5bc89fa",
        "name": "Historial de eventos",
        "func": "// Catalogo visual por tipo de evento\nconst REASON_META = {\n    ok:                    { label: \"ONLINE\",             color: \"#4caf50\", icon: \"🟢\" },\n    shutdown:              { label: \"Apagado controlado\", color: \"#ffc107\", icon: \"🟡\" },\n    no_data_timeout:       { label: \"Sin datos\",          color: \"#ff9800\", icon: \"🟠\" },\n    sensor_fault:          { label: \"Sensor averiado\", color: \"#ff9800\", icon: \"🟠\" },\n    unexpected_disconnect: { label: \"Caída del enlace\",   color: \"#f44336\", icon: \"🔴\" },\n    link_dropped:          { label: \"Desconocido\",        color: \"#9e9e9e\", icon: \"⚫\" },\n    o2_low:                { label: \"O₂ bajo (alarma)\", color: \"#f44336\", icon: \"🔴\" },\n    o2_clear:              { label: \"O₂ recuperado\",    color: \"#4caf50\", icon: \"🟢\" },\n\n};\n\nconst N = 20;\nconst DEDUP_WINDOW_MS = 3000;\nconst list = flow.get(\"events\") || [];\nconst p = msg.payload || {};\n\n// Determina el reason normalizado\nlet reason;\nif      (p.status === \"ONLINE\")  reason = \"ok\";\nelse if (p.status === \"OFFLINE\") reason = p.reason || \"link_dropped\";\nelse                             reason = p.reason || \"link_dropped\";\n\nconst meta = REASON_META[reason] || REASON_META.link_dropped;\n\nconst event = {\n    raw_ts: p.ts || Date.now(),\n    ts:     new Date(p.ts || Date.now()).toLocaleString(\"es-ES\"),\n    node:   p.node || \"unknown\",\n    reason: reason,\n    label:  meta.label,\n    color:  meta.color,\n    icon:   meta.icon\n};\n\n// Deduplicacion: contra TODA la lista, no solo el primer elemento.\n// Cubre el caso \"mismo evento llega por dos caminos (status + alarm) y\n// la segunda copia se cuela entre eventos no relacionados\".\nconst isDup = list.some(prev =>\n    prev.node === event.node\n    && prev.reason === event.reason\n    && Math.abs(event.raw_ts - prev.raw_ts) < DEDUP_WINDOW_MS\n);\nif (isDup) return null;\n\nlist.unshift(event);\n\n// Ordenacion cronologica DESCENDENTE (mas reciente primero).\n// Necesario porque dos eventos MQTT que llegan a este nodo en orden\n// inverso (por jitter de red o por venir de topics distintos) podrian\n// quedar colocados al reves si nos limitamos a unshift().\nlist.sort((a, b) => b.raw_ts - a.raw_ts);\n\nwhile (list.length > N) list.pop();\nflow.set(\"events\", list);\n\nmsg.payload = list;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 520,
